# Diigo API Configuration
# Get your API key from: https://www.diigo.com/user/settings (API Key section)
DIIGO_API_KEY=your_diigo_api_key_here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Optional: Custom database path (default: uses platformdirs for OS-specific config location)
# DIIGO_DB_PATH=/custom/path/to/tags.db
